{
  "name": "@formspree/ajax",
  "version": "1.0.0",
  "private": false,
  "description": "Pure JavaScript AJAX library for Formspree",
  "homepage": "https://formspree.io",
  "bugs": {
    "url": "https://github.com/formspree/formspree-ajax/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/formspree/formspree-ajax.git"
  },
  "license": "MIT",
  "author": "Formspree",
  "contributors": [
    "Formspree"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --minify && node scripts/fix-dts.js",
    "clean": "rm -rf dist && rm -rf node_modules",
    "dev": "tsup src/index.ts --format esm,cjs --dts --sourcemap --watch",
    "lint": "eslint ./src ./test",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@formspree/core": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
